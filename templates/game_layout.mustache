{{!
    @template mod_playerpuzzle/game_layout

    The main layout for the game canvas and accessible question modal.

    Example context (json):
    {
        "gametitle": "Fire Dungeon",
        "loadingtext": "Loading the game engine..."
    }
}}

<div class="playerpuzzle-game-wrapper d-flex flex-column align-items-center mt-3 mb-5">
    <h3 class="mb-3">{{gametitle}}</h3>

    {{! The container where Phaser.js will inject the <canvas> element. }}
    <div id="playerpuzzle-canvas-container" class="border border-2 border-dark rounded shadow-lg"
         aria-label="{{loadingtext}}" role="application"
         data-config="{{gameconfig}}"
         style="width: 100%; max-width: 800px; aspect-ratio: 4/3; margin: 0 auto; overflow: hidden; background-color: #1a1a1a;">
        <p class="text-center p-5 text-muted">{{loadingtext}}</p>
    </div>

    {{! Modal de Pergunta do Jogo }}
    <div id="playerpuzzle-modal" class="modal" tabindex="-1" role="dialog" style="display: none; background: rgba(0,0,0,0.8);">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content shadow-lg border-primary">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">⚔️ Desafio Mágico!</h5>
                </div>
                <div class="modal-body">
                    <h4 id="playerpuzzle-pergunta-texto" class="mb-4">O texto da pergunta vai aparecer aqui...</h4>

                    <div id="playerpuzzle-respostas-container" class="d-grid gap-2">
                        </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" id="playerpuzzle-btn-fechar">Fugir (Ignorar)</button>
                </div>
            </div>
        </div>
    </div>

{{! Accessible BS5 Modal for Moodle Questions }}
<div class="modal fade" id="playerpuzzleQuestionModal" tabindex="-1" aria-labelledby="questionModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="questionModalLabel">{{#str}} answerquestion, mod_playerpuzzle {{/str}}</h5>
                {{! Accessible close button for screen readers }}
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="{{#str}} close, mod_playerpuzzle {{/str}}"></button>
            </div>
            <div class="modal-body">
                <div id="playerpuzzle-question-text" class="fs-5 mb-4">
                    {{! Question text injected via JS will appear here }}
                    &nbsp;
                </div>
                <div id="playerpuzzle-options-container" class="d-grid gap-2">
                    {{! Answer buttons injected via JS will appear here }}
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <div class="visually-hidden" id="playerpuzzle-screenreader-status" aria-live="polite"></div>
                <span class="badge bg-info text-dark fs-6" id="playerpuzzle-timer-badge">
                    <i class="fa fa-clock-o" aria-hidden="true"></i> <span id="playerpuzzle-time-left">00:00</span>
                </span>
            </div>
        </div>
    </div>
</div>
