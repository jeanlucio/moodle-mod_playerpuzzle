{{!
    @template mod_playerpuzzle/gameover_overlay

    Game over overlay rendered client-side inside the canvas container via core/templates.

    Example context (json):
    {
        "colorclass": "text-success",
        "msg": "Victory!",
        "coinscollected": "Coins collected:",
        "playergold": 150,
        "maxmultiplier": "Max multiplier:",
        "playermultiplier": "2.5",
        "savingprogress": "Saving progress...",
        "btnplayagain": "Play Again",
        "btnexitgame": "Exit Game"
    }
}}
<div id="playerpuzzle-gameover" class="d-flex flex-column justify-content-center align-items-center">
    <h1 class="display-4 pp-bold {{colorclass}} mb-3">{{msg}}</h1>
    <p class="lead text-white mb-4">
        {{coinscollected}} <strong class="text-warning">{{playergold}}</strong><br>
        {{maxmultiplier}} <strong class="text-info">x{{playermultiplier}}</strong>
    </p>
    <p id="pp-save-status" class="text-light small">{{savingprogress}}</p>
    <div class="pp-gameover-buttons">
        <button id="btn-pp-restart" disabled class="btn btn-primary btn-lg shadow">
            {{btnplayagain}}
        </button>
        <button id="btn-pp-exit" disabled class="btn btn-secondary btn-lg shadow">
            {{btnexitgame}}
        </button>
    </div>
</div>
