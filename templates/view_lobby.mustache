{{!
    @template mod_playerpuzzle/view_lobby

    Lobby layout for the PlayerPuzzle activity.

    Example context (json):
    {
        "welcomemsg": "Welcome to the Lobby! The Shop and the Play button will be here soon.",
        "playurl": "/mod/playerpuzzle/play.php?id=1",
        "playtext": "Play Game",
        "ismobile": false
    }
}}
<div class="pp-lobby text-center mb-5">
    <p class="lead mt-4">{{welcomemsg}}</p>
    <a href="{{{playurl}}}"
       class="btn btn-primary btn-lg mt-3 px-5 py-3 fs-4 fw-bold shadow-sm"
       {{#ismobile}}target="_blank" rel="noopener"{{/ismobile}}>
        {{playtext}}
    </a>
</div>
